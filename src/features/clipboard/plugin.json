{
  "id": "clipboard",
  "name": "剪贴板历史",
  "version": "1.0.0",
  "description": "搜索剪贴板历史，管理记录类型、过滤规则和快捷键",
  "icon": "qta:mdi6.clipboard-text-outline",
  "entrypoint": "runtime:create_runtime",
  "qmlPage": "ClipboardWindowPage.qml",
  "contextProperty": "clipboardVm",
  "category": "tool",
  "activation": "background",
  "window": {
    "width": 980,
    "height": 640,
    "alwaysOnTop": true
  },
  "order": 7,
  "commands": [
    {
      "id": "clipboard.open",
      "title": "剪贴板历史",
      "subtitle": "在启动器内搜索、预览和管理剪贴板历史",
      "icon": "qta:mdi6.clipboard-text-outline",
      "keywords": ["剪贴板", "clipboard", "复制", "copy", "粘贴", "paste", "历史"],
      "prefixes": ["clip", "clipboard"],
      "launchMode": "window",
      "matchers": [
        {"source": "clipboard", "kind": "clipboard", "boost": 30}
      ]
    }
  ]
}
