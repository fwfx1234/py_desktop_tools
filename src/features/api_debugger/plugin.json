{
  "id": "api-debugger",
  "name": "API 调试器",
  "version": "1.0.0",
  "description": "HTTP/WebSocket 接口测试，支持环境变量、断言、用例",
  "icon": "qta:mdi6.api",
  "entrypoint": "runtime:create_runtime",
  "qmlPage": "ApiDebuggerPage.qml",
  "contextProperty": "apiDebuggerVm",
  "category": "tool",
  "window": {
    "width": 0.8,
    "height": 0.8
  },
  "order": 2,
  "commands": [
    {
      "id": "api-debugger.open",
      "title": "API 调试器",
      "subtitle": "HTTP/WebSocket 接口测试",
      "icon": "qta:mdi6.api",
      "keywords": ["api", "http", "websocket", "接口", "测试", "request"],
      "prefixes": ["api", "http"],
      "launchMode": "window",
      "matchers": [
        {"source": "input", "kind": "url", "boost": 120},
        {"source": "clipboard", "kind": "url", "boost": 70}
      ]
    }
  ]
}
